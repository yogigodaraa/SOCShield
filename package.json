{
  "name": "socshield",
  "version": "2.0.0",
  "description": "AI-Driven Phishing Detection & Response System",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && source venv/bin/activate && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:both": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install": "npm install --prefix frontend",
    "install:all": "npm install --prefix frontend && cd backend && pip install -r requirements.txt",
    "build": "npm run build --prefix frontend",
    "start": "npm start --prefix frontend",
    "test": "npm test --prefix frontend",
    "test:backend": "cd backend && pytest",
    "lint": "npm run lint --prefix frontend"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yogigodaraa/SOCShield"
  },
  "keywords": [
    "security",
    "phishing",
    "ai",
    "detection",
    "soc"
  ],
  "author": "Yogi Godara",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
