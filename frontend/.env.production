# Production environment variables
# Update these with your actual backend URLs

# Backend API URL (Replace with your deployed backend URL)
NEXT_PUBLIC_API_URL=https://your-backend-url.com

# WebSocket URL (Replace with your deployed backend WebSocket URL)
NEXT_PUBLIC_WS_URL=wss://your-backend-url.com/ws

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_REALTIME=true
