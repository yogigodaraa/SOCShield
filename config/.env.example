# Database Configuration
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://socshield:your_secure_password_here@localhost:5432/socshield

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# AI Provider Configuration
# Options: gemini, openai, claude
AI_PROVIDER=gemini

# API Keys for AI Providers
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_claude_api_key_here

# Email Monitoring Configuration
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_email@gmail.com
IMAP_PASSWORD=your_app_password
MONITORED_FOLDERS=INBOX,Spam

# SMTP Configuration (for sending alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=alerts@socshield.io

# Application Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
API_KEY=your_api_key_for_external_integrations

# Alerting Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/WEBHOOK/URL
ENABLE_SMS_ALERTS=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# SIEM Integration
SPLUNK_HOST=splunk.example.com
SPLUNK_PORT=8089
SPLUNK_TOKEN=your_splunk_hec_token

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_TIMEOUT=3600

# Feature Flags
ENABLE_AUTO_QUARANTINE=true
ENABLE_AUTO_BLOCK=false
ENABLE_THREAT_INTEL=true
